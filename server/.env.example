# Variáveis de Ambiente - NUNCA commitar para o git

# Chave secreta para criptografia de licenças (32 bytes em hex = 64 chars)
LICENSE_SECRET=seu_secret_64_caracteres_aqui

# Chave para tokens JWT (64 bytes em hex = 128 chars)
JWT_SECRET=seu_jwt_secret_128_caracteres_aqui

# Secret para autenticação admin (64 bytes em hex)
ADMIN_SECRET=seu_admin_secret_64_caracteres_aqui

# Hash do token admin (gerar com: echo -n "token" | sha256sum)
ADMIN_TOKEN_HASH=seu_admin_token_hash_aqui

# Port do servidor
PORT=3000

# CORS - Domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=https://seudominio.com,https://app.seudominio.com

# Google Play Integrity API (opcional - requer Google Cloud + Google Play Console)
# GOOGLE_CLOUD_PROJECT_NUMBER=123456789012
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# Configurações de segurança adicionais
NODE_ENV=production